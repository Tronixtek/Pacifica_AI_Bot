APP_ENV=development
SERVICE_NAME=pacifica-trader
FRONTEND_ORIGIN=http://127.0.0.1:3000
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_PATH=logs/audit.jsonl
BOT_MODE=paper
PACIFICA_NETWORK=testnet
PACIFICA_REST_URL=https://test-api.pacifica.fi/api/v1
PACIFICA_WS_URL=wss://test-ws.pacifica.fi/ws
PACIFICA_ACCOUNT_ADDRESS=
PACIFICA_AGENT_PRIVATE_KEY=
PACIFICA_API_CONFIG_KEY=
PACIFICA_BUILDER_CODE=
SYMBOLS=BTC,ETH,SOL
USE_SIMULATED_FEED=true
PREFER_WEBSOCKET_FEED=true
ENABLE_LIVE_TRADING=false
POLL_INTERVAL_SEC=2.0
ACCOUNT_SYNC_INTERVAL_SEC=10.0
MARKET_DATA_STALE_AFTER_SEC=15.0
WS_HEARTBEAT_SEC=20.0
STARTING_EQUITY_USD=10000
MAX_RISK_PER_TRADE_PCT=0.75
MIN_SIGNAL_CONFIDENCE=0.72
MAX_DAILY_LOSS_PCT=3.0
ENFORCE_DAILY_LOSS_LIMIT=false
MAX_OPEN_POSITIONS=3
DEFAULT_LEVERAGE=3.0
SIGNAL_COOLDOWN_SECONDS=45
PRICE_ACTION_BREAKOUT_WINDOW=20
PRICE_ACTION_SWEEP_WINDOW=12
PRICE_ACTION_TREND_FAST_WINDOW=8
PRICE_ACTION_TREND_SLOW_WINDOW=34
PRICE_ACTION_MOMENTUM_WINDOW=5
PRICE_ACTION_BREAKOUT_BUFFER=0.0016
PRICE_ACTION_REWARD_TO_RISK=2.1
SIGNATURE_EXPIRY_WINDOW_MS=5000
SLIPPAGE_PERCENT=0.35
ML_ENABLED=true
ML_CANDLE_INTERVAL=1m
ML_TRAINING_LOOKBACK_CANDLES=720
ML_PREDICTION_HORIZON_BARS=5
ML_TARGET_MOVE_PCT=0.18
ML_MIN_TRADE_PROBABILITY=0.58
ML_PROBABILITY_EDGE=0.04
ML_RETRAIN_INTERVAL_SEC=1800
ML_PREFER_LOCAL_DATASET=true
ML_DATASET_ROOT=data/training
ML_LOAD_ARTIFACT_ON_STARTUP=true
ML_MODEL_ARTIFACT_PATH=models/ml_signal_model.json
PERSIST_RUNTIME_STATE=true
STATE_STORE_PATH=data/state/runtime.sqlite3
STATE_CHECKPOINT_INTERVAL_SEC=5.0
